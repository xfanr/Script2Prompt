{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "useDefineForClassFields":  true,
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "strict":  true,
                            "jsx":  "preserve",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "lib":  [
                                        "ES2022",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "skipLibCheck":  true,
                            "types":  [
                                          "element-plus/global"
                                      ],
                            "noEmit":  true
                        },
    "include":  [
                    "src/**/*.ts",
                    "src/**/*.d.ts",
                    "src/**/*.tsx",
                    "src/**/*.vue"
                ]
}
